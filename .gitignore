# Raw data (large, not version controlled)
data/

# Generated artifacts (large) — keep the dirs via .gitkeep, ignore contents
datasets/*
!datasets/.gitkeep
calibrations/*
!calibrations/.gitkeep

# Calibration-study outputs (generated on the VM). Keep each experiment's
# scaffold (EXPERIMENT.md, run.sh, analyze.py, config_snapshot/) tracked, but
# ignore the per-run calibrations, figures and aggregated results.
experiments/*/runs/
experiments/*/run_manifest.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# Environments
.venv/

# Model checkpoints
*.pt
*.pth

# Detector training run outputs (checkpoints/metrics/provenance) — large
runs/
